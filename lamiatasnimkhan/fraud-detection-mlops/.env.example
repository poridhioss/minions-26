# Copy to .env and fill in. .env is git-ignored.
# Never commit real secrets.

# --- Kaggle (for fetching the dataset; not needed for training/serving) ---
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=KGAT_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- MLflow ---
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=fraud-detection

# --- Model / registry ---
MODEL_NAME=FraudDetector
MODEL_STAGE=Production
LOCAL_MODEL_PATH=models/model.pkl

# --- Training ---
TRAIN_CSV=data/raw/creditcard.csv
RANDOM_STATE=42
TEST_SIZE=0.2

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

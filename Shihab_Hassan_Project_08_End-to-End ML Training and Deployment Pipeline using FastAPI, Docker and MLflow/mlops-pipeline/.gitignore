# .gitignore
# Standard Python + ML + IDE ignore rules.

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
.venv/
venv/
env/
ENV/
.puku/
*.db

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
pip-wheel-metadata/

# Testing / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# ---------- Project artifacts ----------
# Don't commit large or regenerable outputs.
mlruns/
models/*.joblib
models/*.pkl
models/*.json
!models/.gitkeep

# Logs
*.log

# ---------- IDEs / editors ----------
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ---------- OS ----------
.DS_Store
desktop.ini

# ---------- Jupyter ----------
.ipynb_checkpoints/
*.ipynb
!notebooks/*.ipynb

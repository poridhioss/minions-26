# ── Sandbox image settings ─────────────────────────────────
DOCKER_IMAGE=code-runner:latest
DOCKER_TIMEOUT=10          # max execution seconds
DOCKER_MEMORY=128m         # hard memory cap per container
DOCKER_CPU_QUOTA=0.5       # 1.0 = 1 full CPU

# ── App-level safety limits ────────────────────────────────
MAX_CODE_LENGTH=10000      # reject code longer than this
RATE_LIMIT_PER_MIN=30      # per-IP requests per minute

# ── Storage ────────────────────────────────────────────────
DB_PATH=data/history.db

# Puku Job Orchestrator — root env (auto-loaded by `docker compose`).
# This file lives at the REPO ROOT, NOT inside backend/, so that
# `docker compose` (which auto-loads ./.env from the project root) picks
# it up. The backend container then forwards these as process env.
#
# For running the backend directly (npm run dev:*), use backend/.env
# instead, which docker won't see.


API_KEY=your-api-key

# Optional overrides (defaults shown — uncomment to change):
# PORT=3000
# LOG_LEVEL=info
# WORKER_CONCURRENCY=2
# JOB_TIMEOUT_MS=300000

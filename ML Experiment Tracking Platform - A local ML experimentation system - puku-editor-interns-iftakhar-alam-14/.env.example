# ─── .env.example ────────────────────────────────────────────────────────
# Copy this file to `.env` and adjust for your environment. The values
# below match the defaults in docker-compose.yml — change them before
# exposing the stack to the internet.
# ─────────────────────────────────────────────────────────────────────────

# ─── Postgres ─────────────────────────────────────────────────────────────
POSTGRES_USER=mluser
POSTGRES_PASSWORD=changeme-in-production
POSTGRES_DB=mltracker
# The backend talks to Postgres using this URL. With docker-compose the
# hostname is the SERVICE name (postgres), not localhost.
DATABASE_URL=postgresql://mluser:changeme-in-production@postgres:5432/mltracker

# ─── Security ─────────────────────────────────────────────────────────────
# Generate a strong random key in production:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-48-char-random-string
# Comma-separated. The first key is what the SDK / curl examples use.
API_KEYS=dev-key-12345
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── MLflow ───────────────────────────────────────────────────────────────
# MLflow server URL — referenced by the backend AND the training scripts.
MLFLOW_TRACKING_URI=http://mlflow:5000
# Where MLflow stores artifacts inside the mlflow container. The compose
# file mounts this path to a named volume so runs survive restarts.
MLFLOW_ARTIFACT_ROOT=/mlflow/artifacts

# ─── MinIO (S3-compatible artifact store) ───────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme-minio-password
MINIO_BUCKET=artifacts
MINIO_SECURE=False

# ─── App ──────────────────────────────────────────────────────────────────
APP_NAME=ML Experiment Tracker
APP_VERSION=0.1.0
DEBUG=False
# Comma-separated. The nginx container serves the frontend on :80, so
# http://localhost is the correct origin.
CORS_ORIGINS=http://localhost,http://localhost:80
